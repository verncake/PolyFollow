// Prisma Schema for Polymarket Follow-Alpha System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User table - stores authenticated users
model User {
  id               String              @id @default(cuid())
  wallet_address   String              @unique @map("wallet_address")
  created_at       DateTime            @default(now()) @map("created_at")
  updated_at       DateTime            @updatedAt @map("updated_at")
  followed_addresses FollowedAddress[]

  @@map("users")
}

// FollowedAddress - many-to-many relationship for user following traders
model FollowedAddress {
  id                String   @id @default(cuid())
  user_id           String   @map("user_id")
  follower_id       String   @map("follower_id")
  created_at        DateTime @default(now()) @map("created_at")

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  leaderboard_entry LeaderboardAddress @relation(fields: [follower_id], references: [id], onDelete: Cascade)

  @@unique([user_id, follower_id])
  @@map("followed_addresses")
}

// LeaderboardAddress - stores top traders from Polymarket
model LeaderboardAddress {
  id                String    @id @default(cuid())
  address           String    @unique
  rank              Int
  win_rate          Decimal   @map("win_rate") @db.Decimal(5, 4)
  profit_factor     Decimal   @map("profit_factor") @db.Decimal(10, 6)
  total_trades      Int       @map("total_trades")
  total_pnl         Decimal   @map("total_pnl") @db.Decimal(20, 6)
  score             Int       // 0-100综合评分
  last_updated      DateTime  @map("last_updated") @db.Timestamptz
  created_at        DateTime  @default(now()) @map("created_at")
  updated_at        DateTime  @updatedAt @map("updated_at")

  positions         Position[]
  followers         FollowedAddress[]

  @@index([rank])
  @@index([score])
  @@map("leaderboard_addresses")
}

// Position - stores trader's positions on Polymarket
model Position {
  id                    String    @id @default(cuid())
  leaderboard_address_id String   @map("leaderboard_address_id")
  market_id             String    @map("market_id")
  condition_id          String    @map("condition_id")
  collateral_token      String   @map("collateral_token")

  // Position details
  side                  String    // "BUY" or "SELL"
  size                  Decimal   @map("size") @db.Decimal(20, 6)
  entry_price           Decimal   @map("entry_price") @db.Decimal(10, 6)
  current_price         Decimal   @map("current_price") @db.Decimal(10, 6)
  avg_fill_price        Decimal   @map("avg_fill_price") @db.Decimal(10, 6)

  // P/L calculations
  unrealized_pnl        Decimal   @map("unrealized_pnl") @db.Decimal(20, 6)
  realized_pnl          Decimal   @map("realized_pnl") @db.Decimal(20, 6)

  // Status tracking
  status                String    // "OPEN" or "CLOSED"
  opened_at             DateTime? @map("opened_at") @db.Timestamptz
  closed_at             DateTime? @map("closed_at") @db.Timestamptz
  created_at            DateTime  @default(now()) @map("created_at")
  updated_at            DateTime  @updatedAt @map("updated_at")

  leaderboard_address   LeaderboardAddress @relation(fields: [leaderboard_address_id], references: [id], onDelete: Cascade)

  @@index([leaderboard_address_id])
  @@index([market_id])
  @@index([status])
  @@map("positions")
}

// Trade - stores individual trades for history
model Trade {
  id                    String    @id @default(cuid())
  leaderboard_address_id String   @map("leaderboard_address_id")
  market_id             String    @map("market_id")
  condition_id          String    @map("condition_id")

  // Trade details
  side                  String    // "BUY" or "SELL"
  size                  Decimal   @map("size") @db.Decimal(20, 6)
  price                 Decimal   @map("price") @db.Decimal(10, 6)
  filled_qty            Decimal   @map("filled_qty") @db.Decimal(20, 6)
  fees                  Decimal   @map("fees") @db.Decimal(20, 6)

  // Transaction info
  transaction_hash      String    @map("transaction_hash")
  block_number          Int       @map("block_number")
  timestamp             DateTime  @map("timestamp") @db.Timestamptz
  created_at            DateTime  @default(now()) @map("created_at")

  @@index([leaderboard_address_id])
  @@index([market_id])
  @@index([timestamp])
  @@map("trades")
}
